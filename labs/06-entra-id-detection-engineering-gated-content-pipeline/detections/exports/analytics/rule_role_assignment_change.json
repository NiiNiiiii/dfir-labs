{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/b96dd5e9-68dd-4f49-af1f-7874a0c31830')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/b96dd5e9-68dd-4f49-af1f-7874a0c31830')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "LAB06 - Directory role assignment change",
                "description": "Detect Microsoft Entra directory role assignment or role membership changes that may increase cloud privileges or persistence.",
                "severity": "High",
                "enabled": true,
                "query": "let lookback = 1h;\r\nAuditLogs\r\n| where TimeGenerated >= ago(lookback)\r\n| where OperationName in (\"Add member to role\", \"Remove member from role\")\r\n| extend InitiatingUserUPN = tostring(InitiatedBy.user.userPrincipalName)\r\n| extend InitiatingAppName = tostring(InitiatedBy.app.displayName)\r\n| extend Actor = coalesce(InitiatingUserUPN, InitiatingAppName, \"unknown\")\r\n| mv-expand TargetResources\r\n| extend TargetDisplayName = tostring(TargetResources.displayName)\r\n| extend TargetId = tostring(TargetResources.id)\r\n| extend TargetType = tostring(TargetResources.type)\r\n| extend ActorName = iff(indexof(InitiatingUserUPN, \"@\") != -1, tostring(split(InitiatingUserUPN, \"@\")[0]), Actor)\r\n| extend ActorUPNSuffix = iff(indexof(InitiatingUserUPN, \"@\") != -1, tostring(split(InitiatingUserUPN, \"@\")[1]), \"\")\r\n| project TimeGenerated, OperationName, ResultType, ResultDescription, LoggedByService, CorrelationId, Actor, InitiatingUserUPN, InitiatingAppName, ActorName, ActorUPNSuffix, TargetDisplayName, TargetId, TargetType\r\n",
                "queryFrequency": "PT1H",
                "queryPeriod": "PT1H",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 0,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [
                    "Persistence",
                    "PrivilegeEscalation"
                ],
                "techniques": [
                    "T1098"
                ],
                "subTechniques": [],
                "alertRuleTemplateName": null,
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": false,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "PT5H",
                        "matchingMethod": "AllEntities",
                        "groupByEntities": [],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": []
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": null,
                "customDetails": {
                    "OperationName": "OperationName",
                    "TargetDisplayName": "TargetDisplayName",
                    "TargetType": "TargetType",
                    "CorrelationId": "CorrelationId"
                },
                "entityMappings": [
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "Name",
                                "columnName": "ActorName"
                            },
                            {
                                "identifier": "UPNSuffix",
                                "columnName": "ActorUPNSuffix"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": null,
                "templateVersion": null
            }
        }
    ]
}