{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "id": "[concat(resourceId('Microsoft.OperationalInsights/workspaces/providers', parameters('workspace'), 'Microsoft.SecurityInsights'),'/alertRules/aad9d816-a10a-4ae2-bc25-62599c81f254')]",
            "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/aad9d816-a10a-4ae2-bc25-62599c81f254')]",
            "type": "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "kind": "Scheduled",
            "apiVersion": "2023-12-01-preview",
            "properties": {
                "displayName": "LAB06 - Failed sign-in burst by IP",
                "description": "Detect repeated failed Microsoft Entra interactive sign-ins from a single source IP across multiple users within a short time window, consistent with password spraying or brute-force activity.",
                "severity": "Medium",
                "enabled": true,
                "query": "let lookback = 15m;\r\nlet minFailures = 5;\r\nlet minDistinctUsers = 3;\r\nSigninLogs\r\n| where TimeGenerated >= ago(lookback)\r\n| where ResultType != 0\r\n| summarize\r\n    StartTime=min(TimeGenerated),\r\n    EndTime=max(TimeGenerated),\r\n    FailureCount=count(),\r\n    FailedUsersCount=dcount(UserPrincipalName),\r\n    FailedUsers=make_set(UserPrincipalName, 20),\r\n    AppDisplayNames=make_set(AppDisplayName, 10),\r\n    SampleResultDescriptions=make_set(ResultDescription, 5)\r\n  by IPAddress\r\n| where FailureCount >= minFailures and FailedUsersCount >= minDistinctUsers\r\n| extend TimeGenerated = EndTime\r\n| extend FirstUser = tostring(FailedUsers[0])\r\n| extend FirstUserName = iff(indexof(FirstUser, \"@\") != -1, tostring(split(FirstUser, \"@\")[0]), FirstUser)\r\n| extend FirstUserUPNSuffix = iff(indexof(FirstUser, \"@\") != -1, tostring(split(FirstUser, \"@\")[1]), \"\")\r\n| project TimeGenerated, IPAddress, FailureCount, FailedUsersCount, FailedUsers, AppDisplayNames, SampleResultDescriptions, StartTime, EndTime, FirstUser, FirstUserName, FirstUserUPNSuffix\r\n",
                "queryFrequency": "PT15M",
                "queryPeriod": "PT15M",
                "triggerOperator": "GreaterThan",
                "triggerThreshold": 0,
                "suppressionDuration": "PT5H",
                "suppressionEnabled": false,
                "startTimeUtc": null,
                "tactics": [
                    "CredentialAccess"
                ],
                "techniques": [
                    "T1110"
                ],
                "subTechniques": [],
                "alertRuleTemplateName": null,
                "incidentConfiguration": {
                    "createIncident": true,
                    "groupingConfiguration": {
                        "enabled": false,
                        "reopenClosedIncident": false,
                        "lookbackDuration": "PT5H",
                        "matchingMethod": "AllEntities",
                        "groupByEntities": [],
                        "groupByAlertDetails": [],
                        "groupByCustomDetails": []
                    }
                },
                "eventGroupingSettings": {
                    "aggregationKind": "SingleAlert"
                },
                "alertDetailsOverride": null,
                "customDetails": {
                    "FailureCount": "FailureCount",
                    "FailedUsersCount": "FailedUsersCount",
                    "FailedUsers": "FailedUsers",
                    "AppDisplayNames": "AppDisplayNames"
                },
                "entityMappings": [
                    {
                        "entityType": "Account",
                        "fieldMappings": [
                            {
                                "identifier": "Name",
                                "columnName": "FirstUserName"
                            },
                            {
                                "identifier": "UPNSuffix",
                                "columnName": "FirstUserUPNSuffix"
                            }
                        ]
                    },
                    {
                        "entityType": "IP",
                        "fieldMappings": [
                            {
                                "identifier": "Address",
                                "columnName": "IPAddress"
                            }
                        ]
                    }
                ],
                "sentinelEntitiesMappings": null,
                "templateVersion": null
            }
        }
    ]
}